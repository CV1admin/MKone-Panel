rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, displayName, email, photoURL, role, createdAt
    //
    // Collection: projects
    // Fields: id, name, description, ownerId, collaborators, createdAt, updatedAt, isPublic
    //
    // Collection: projects/{projectId}/agents
    // Fields: id, projectId, name, model, skills, memory, status
    //
    // Collection: modules
    // Fields: id, name, description, type, config, authorId
    //
    // Collection: solutions
    // Fields: id, projectId, name, results, visualizations, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "marekkplw@gmail.com" && request.auth.token.email_verified == true));
    }

    function isProjectMember(projectId) {
      let project = get(/databases/$(database)/documents/projects/$(projectId)).data;
      return isAuthenticated() && (project.ownerId == request.auth.uid || request.auth.uid in project.collaborators);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('role' in data) || data.role in ['admin', 'user']);
    }

    function isValidProject(data) {
      return data.keys().hasAll(['name', 'ownerId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.ownerId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && (resource.data.isPublic == true || isProjectMember(projectId));
      allow create: if isAuthenticated() && isValidProject(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isProjectMember(projectId) && isValidProject(request.resource.data);
      allow delete: if isAuthenticated() && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;

      match /agents/{agentId} {
        allow read, write: if isProjectMember(projectId);
      }
    }

    match /modules/{moduleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    match /solutions/{solutionId} {
      allow read: if isAuthenticated() && isProjectMember(resource.data.projectId);
      allow create: if isAuthenticated() && isProjectMember(request.resource.data.projectId);
      allow update, delete: if isAuthenticated() && isProjectMember(resource.data.projectId);
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
